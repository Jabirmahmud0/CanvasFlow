# CanvasFlow Environment Variables

# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control!

# ============================================
# Sentry Error Monitoring
# ============================================
# Get your DSN from https://sentry.io
# Production DSN (replace with yours)
VITE_SENTRY_DSN=https://eb35e25796e4e4fae87c6564fbd785e3@o4511144793014272.ingest.us.sentry.io/4511144794259456

# Environment name (development, staging, production)
VITE_SENTRY_ENVIRONMENT=development

# Performance tracing sample rate (0.0 - 1.0)
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2

# ============================================
# Analytics Configuration
# ============================================
# Provider: google, plausible, fathom, custom
VITE_ANALYTICS_PROVIDER=google

# Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX)
VITE_ANALYTICS_ID=G-2CLJP2E46L

# Domain for Plausible/Fathom
VITE_ANALYTICS_DOMAIN=

# Custom analytics config (JSON string)
# VITE_ANALYTICS_CONFIG={}

# ============================================
# API Configuration (if applicable)
# ============================================
# VITE_API_URL=https://api.canvasflow.app
# VITE_WS_URL=wss://ws.canvasflow.app

# ============================================
# Feature Flags
# ============================================
# VITE_FEATURE_COLLABORATION=false
# VITE_FEATURE_CLOUD_SAVE=false

# ============================================
# Vercel Deployment
# ============================================
# These variables should be configured in Vercel dashboard
# Go to Project Settings > Environment Variables
# 
# Production:
#   VITE_SENTRY_DSN
#   VITE_SENTRY_ENVIRONMENT=production
#   VITE_ANALYTICS_PROVIDER
#   VITE_ANALYTICS_ID
#
# Preview (Pull Requests):
#   VITE_SENTRY_ENVIRONMENT=preview
#
# Development:
#   VITE_SENTRY_ENVIRONMENT=development
