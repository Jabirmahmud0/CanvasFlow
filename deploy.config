# Deploy configuration for CanvasFlow

# Production deployment settings
[production]
  # Build output directory
  output = "dist"
  
  # Deploy branch
  branch = "main"
  
  # Environment variables (set these in GitHub Secrets)
  # VITE_SENTRY_DSN
  # VITE_API_URL
  
  # Performance budgets
  [production.budgets]
    js_bundle_max = "800KB"
    css_bundle_max = "100KB"
    total_bundle_max = "1MB"
    lighthouse_performance_min = 90
    lighthouse_accessibility_min = 90
    lighthouse_best_practices_min = 90
    lighthouse_seo_min = 90

# Staging deployment settings
[staging]
  output = "dist"
  branch = "develop"
  
  # More lenient budgets for staging
  [staging.budgets]
    js_bundle_max = "1MB"
    css_bundle_max = "150KB"

# Preview deployments (for PRs)
[preview]
  enabled = true
  branch_pattern = "feature/*"
